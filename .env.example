# Скопируйте в .env и заполните значения.
# Токен бота: @BotFather в Telegram.

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_or_channel_id

RSS_FEED_URL=https://example.com/news/rss

# Docker Compose подставляет свой DATABASE_URL в сервисе app.
# Локально без Docker: оставьте пустым и используйте SQLite:
# DATABASE_PATH=data/seen_posts.db
#
# Или явно PostgreSQL:
# DATABASE_URL=postgresql://user:pass@localhost:5432/rss

DATABASE_PATH=data/seen_posts.db

# Интервал опроса RSS в секундах (для шедулера)
POLL_INTERVAL_SECONDS=300

# Порт HTTP /metrics для Prometheus (docker-compose задаёт 9091 для сервиса app)
# METRICS_PORT=9091
